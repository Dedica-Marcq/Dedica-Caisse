{
  "name": "dedica-caisse",
  "version": "0.6.0",
  "description": "Logiciel de caisse pour le salon du livre Dedica'Marcq",
  "keywords": [],
  "homepage": "https://github.com/Dedica-Marcq/Dedica-Caisse#readme",
  "bugs": {
    "url": "https://github.com/Dedica-Marcq/Dedica-Caisse/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dedica-Marcq/Dedica-Caisse.git"
  },
  "license": "UNLICENSED",
  "author": "Basile BARGIBANT <webmaster@dedica-marcq.com>",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "mysql2": "^3.14.1",
    "nodemailer": "^7.0.9",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-dmg": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/publisher-github": "^7.10.2",
    "electron": "^37.0.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "appBundleId": "com.dedica-marcq.Dedica-Caisse",
        "appCategoryType": "public.app-category.business",
        "icon": "src/images/logo.icns"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-dmg",
          "config": {
            "format": "ULFO"
          }
        },
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {}
        }
      ]
    }
  }
}
