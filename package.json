{
  "name": "dedica-caisse",
  "version": "0.3.2",
  "main": "main.js",
  "keywords": [],
  "author": "Basile BARGIBANT",
  "license": "ISC",
  "description": "Logiciel de caisse pour le salon du livre Dedica'Marcq",
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "bootstrap-icons": "^1.13.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "mysql2": "^3.14.1",
    "pdfkit": "^0.17.2"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.dedica-marcq.Dedica-Caisse",
    "productName": "Dédica'Caisse",
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  }
}