{
  "name": "dedica-caisse",
  "version": "0.4.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "keywords": [],
  "author": "Basile BARGIBANT",
  "license": "ISC",
  "description": "Logiciel de caisse pour le salon du livre Dedica'Marcq",
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "bootstrap-icons": "^1.13.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "mysql2": "^3.14.1",
    "pdfkit": "^0.17.2"
  },
  "build": {
    "appId": "com.dedica-marcq.Dedica-Caisse",
    "productName": "DedicaCaisse",
    "mac": {
      "category": "public.app-category.business",
      "icon": "src/images/logo.png",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "src/images/logo.png",
      "target": ["nsis", "zip"]
    }
  }
